---
const navLinks = [
  { href: '/kalender/2026',        label: 'Kalender' },
  { href: '/ramadan/2026',         label: 'Ramadan' },
  { href: '/sholat/jakarta',       label: 'Jadwal Sholat' },
  { href: '/hari-besar/idul-fitri/2026', label: 'Hari Besar' },
  { href: '/konversi',             label: 'Konversi' },
  { href: '/weton',                label: 'Weton' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-[100] h-[60px] flex items-center"
  style="background: rgba(253,250,244,.92); backdrop-filter: blur(12px);
         border-bottom: 1px solid rgba(29,107,66,.12);"
>
  <div class="w-full max-w-site mx-auto px-[clamp(1rem,4vw,3rem)] flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 no-underline">
      <div
        class="w-[34px] h-[34px] rounded-lg flex items-center justify-center flex-shrink-0"
        style="background: var(--green-700);"
      >
        <svg width="22" height="22" viewBox="0 0 32 32" fill="none">
          <path d="M16 4 C23.2 4 29 9.8 29 17 C29 24.2 23.2 30 16 30 C19.8 27.2 22 22.5 22 17 C22 11.5 19.8 6.8 16 4 Z" fill="#E2BC45"/>
          <polygon points="27,4 27.8,6.4 30.4,6.4 28.3,7.9 29.1,10.3 27,8.8 24.9,10.3 25.7,7.9 23.6,6.4 26.2,6.4" fill="#E2BC45"/>
        </svg>
      </div>
      <span style="font-family: 'Lora', serif; font-size: 1.05rem; font-weight: 600;
                   color: var(--green-800); line-height: 1;">
        KalenderIslam<span style="color: var(--green-500);">.id</span>
      </span>
    </a>

    <!-- Nav Links (desktop) -->
    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="px-3 py-1.5 rounded-md text-[0.82rem] font-medium transition-colors duration-150"
          style={currentPath.startsWith(link.href.split('/').slice(0,2).join('/'))
            ? 'color: var(--green-600);'
            : 'color: var(--ink-muted);'}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA Button -->
    <div class="flex items-center gap-3">
      <a
        href="/kalender/2026"
        class="hidden sm:inline-flex items-center px-4 py-[7px] rounded-lg
               text-[0.8rem] font-semibold transition-colors duration-150"
        style="background: var(--green-700); color: #FFFFFF !important; letter-spacing: 0.01em;"
        onmouseover="this.style.background='var(--green-600)'"
        onmouseout="this.style.background='var(--green-700)'"
      >
        Lihat Kalender
      </a>

      <!-- Hamburger (mobile) -->
      <button
        id="nav-toggle"
        class="md:hidden w-9 h-9 flex flex-col items-center justify-center gap-1.5"
        aria-label="Buka menu navigasi"
      >
        <span class="w-5 h-0.5 rounded-full" style="background: var(--ink-muted);"></span>
        <span class="w-5 h-0.5 rounded-full" style="background: var(--ink-muted);"></span>
        <span class="w-4 h-0.5 rounded-full" style="background: var(--ink-muted);"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu (hidden by default) -->
  <div
    id="mobile-menu"
    class="hidden absolute top-[60px] left-0 right-0 shadow-lg md:hidden"
    style="background: rgba(253,250,244,.98); border-bottom: 1px solid rgba(29,107,66,.12);"
  >
    <nav class="flex flex-col py-2 px-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="py-3 text-[0.9rem] font-medium transition-colors duration-150"
          style="color: var(--ink-muted); border-bottom: 1px solid rgba(29,107,66,.08);"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/kalender/2026"
        class="mt-3 mb-2 py-2.5 rounded-lg text-center text-[0.85rem] font-semibold"
        style="background: var(--green-700); color: #FFFFFF !important;"
      >
        Lihat Kalender
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu   = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
