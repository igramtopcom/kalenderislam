---
const currentYear = new Date().getFullYear();

const footerLinks = {
  'Kalender': [
    { href: '/kalender/2026',       label: 'Kalender Islam 2026' },
    { href: '/kalender/2027',       label: 'Kalender Islam 2027' },
    { href: '/kalender-jawa/2026',  label: 'Kalender Jawa 2026' },
    { href: '/libur-nasional/2026', label: 'Hari Libur 2026' },
  ],
  'Ramadan': [
    { href: '/ramadan/2026',         label: 'Ramadan 2026' },
    { href: '/ramadan/2026/jakarta', label: 'Imsakiyah Jakarta' },
    { href: '/ramadan/2026/surabaya',label: 'Imsakiyah Surabaya' },
    { href: '/ramadan/2026/bandung', label: 'Imsakiyah Bandung' },
  ],
  'Hari Besar': [
    { href: '/hari-besar/idul-fitri/2026',  label: 'Idul Fitri 2026' },
    { href: '/hari-besar/idul-adha/2026',   label: 'Idul Adha 2026' },
    { href: '/hari-besar/ramadan/2026',     label: 'Ramadan 2026' },
    { href: '/hari-besar/maulid-nabi/2026', label: 'Maulid Nabi 2026' },
  ],
  'Tools': [
    { href: '/konversi',       label: 'Konversi Tanggal' },
    { href: '/weton',          label: 'Kalkulator Weton' },
    { href: '/sholat/jakarta', label: 'Jadwal Sholat' },
  ],
};
---

<footer style="background: var(--green-900); color: white;">
  <div class="max-w-site mx-auto px-[clamp(1rem,4vw,3rem)] pt-12 pb-8">

    <!-- Top: Logo + Links Grid -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-8 pb-10"
         style="border-bottom: 1px solid rgba(255,255,255,.08);">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2 no-underline mb-4">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center"
               style="background: var(--green-700);">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
              <path d="M10 2L11.5 7H17L12.5 10.5L14 15.5L10 12L6 15.5L7.5 10.5L3 7H8.5L10 2Z"
                    fill="#E2BC45"/>
            </svg>
          </div>
          <span style="font-family:'Lora',serif; font-size:1rem; font-weight:600; color:white;">
            KalenderIslam<span style="color:var(--green-400);">.id</span>
          </span>
        </a>
        <p class="text-[0.8rem] leading-relaxed" style="color: var(--green-200); opacity: .7;">
          Kalender Islam terlengkap untuk Muslim Indonesia.
          Hijriah, Masehi, dan Jawa dalam satu tampilan.
        </p>
      </div>

      <!-- Links Grid -->
      {Object.entries(footerLinks).map(([category, links]) => (
        <div>
          <h3 class="text-[0.72rem] font-semibold uppercase tracking-widest mb-4"
              style="color: var(--green-200); opacity: .6;">
            {category}
          </h3>
          <ul class="space-y-2.5 list-none p-0 m-0">
            {links.map(link => (
              <li>
                <a href={link.href}
                   class="text-[0.82rem] transition-colors duration-150 no-underline"
                   style="color: rgba(255,255,255,.65);"
                   onmouseover="this.style.color='white'"
                   onmouseout="this.style.color='rgba(255,255,255,.65)'">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom: Copyright -->
    <div class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-[0.75rem]" style="color: rgba(255,255,255,.4);">
        &copy; {currentYear} KalenderIslam.id
      </p>
      <p class="text-[0.72rem]" style="color: rgba(255,255,255,.3);">
        Data Hijri: Kemenag RI + Umm al-Qura projection
      </p>
    </div>
  </div>
</footer>
