---
import { generateMonthCalendar } from '@/lib/calendar';
import type { NationalHoliday, ProcessedOfficialDate } from '@/lib/types';

interface Props {
  year:          number;
  month:         number;       // 0-indexed
  holidays:      NationalHoliday[];
  officialDates?: ProcessedOfficialDate[];
  compact?:      boolean;
  showNav?:      boolean;
}

const {
  year, month,
  holidays = [],
  compact = false,
  showNav = true,
} = Astro.props;

const holidayMap = new Map(holidays.map(h => [h.tanggal, h]));
const cal = generateMonthCalendar(year, month, holidayMap);

const HARI_LABEL = ['Min','Sen','Sel','Rab','Kam','Jum','Sab'];

const BULAN_INDO = [
  'januari','februari','maret','april','mei','juni',
  'juli','agustus','september','oktober','november','desember'
];
const prevUrl = `/kalender/${cal.prevMonth.year}/${BULAN_INDO[cal.prevMonth.month]}`;
const nextUrl = `/kalender/${cal.nextMonth.year}/${BULAN_INDO[cal.nextMonth.month]}`;
---

<div
  class="rounded-[20px] overflow-hidden"
  style="background:white; border:1px solid rgba(29,107,66,.12);
         box-shadow: 0 4px 24px rgba(13,61,34,.06);"
>
  <!-- Header -->
  <div
    class="flex items-center justify-between px-5 py-4"
    style="background:var(--green-50); border-bottom:1px solid rgba(29,107,66,.12);"
  >
    <div>
      <h2 class="text-[1.05rem] font-semibold"
          style="font-family:'Lora',serif; color:var(--ink);">
        {cal.monthName} {cal.year}
      </h2>
      <p class="text-[0.78rem]" style="color:var(--ink-light);">
        {cal.hijriLabel}
      </p>
    </div>

    {showNav && (
      <div class="flex items-center gap-2">
        <a
          href={prevUrl}
          class="w-[30px] h-[30px] rounded-lg flex items-center justify-center
                 transition-colors duration-150 no-underline text-sm"
          style="border:1px solid rgba(29,107,66,.12); background:white; color:var(--ink-muted) !important;"
          aria-label="Bulan sebelumnya"
        >‹</a>
        <a
          href={nextUrl}
          class="w-[30px] h-[30px] rounded-lg flex items-center justify-center
                 transition-colors duration-150 no-underline text-sm"
          style="border:1px solid rgba(29,107,66,.12); background:white; color:var(--ink-muted) !important;"
          aria-label="Bulan berikutnya"
        >›</a>
      </div>
    )}
  </div>

  <!-- Day Headers -->
  <div class="grid grid-cols-7 px-3 pt-3 pb-1" style="gap:2px;">
    {HARI_LABEL.map((hari, i) => (
      <div class="text-center text-[0.68rem] font-semibold uppercase tracking-wider pb-2"
           style={i === 5
             ? 'color:var(--green-600);'
             : 'color:var(--ink-light);'}>
        {hari}
      </div>
    ))}
  </div>

  <!-- Calendar Grid: 42 cells = 6 rows × 7 columns -->
  <div class="grid grid-cols-7 px-3 pb-3" style="gap:2px;">
    {cal.days.map(day => (
      <div
        class={`
          relative aspect-square rounded-[10px] flex flex-col items-center
          justify-center py-1 transition-colors duration-150
          ${day.isOtherMonth ? 'opacity-30' : 'cursor-pointer'}
          ${!day.isToday && !day.isOtherMonth ? 'hover:bg-green-50' : ''}
        `}
        style={day.isToday ? 'background:var(--green-700);' : ''}
        title={day.isOtherMonth ? '' : (day.holidayName ?? `${day.dayMasehi} ${day.hijri.monthName} ${day.hijri.year} H — ${day.jawa.weton}`)}
      >
        {/* .d-masehi: 0.85rem/600 */}
        <span
          class="leading-none"
          style={`font-size:0.85rem; font-weight:600;
            color:${day.isToday
              ? '#FFFFFF'
              : day.isFriday
                ? 'var(--green-700)'
                : 'var(--ink)'};`}
        >
          {day.dayMasehi}
        </span>

        {/* .d-hijri: 0.58rem/400 */}
        <span
          class="leading-none mt-0.5"
          style={`font-size:0.58rem; font-weight:400;
            color:${day.isToday ? 'var(--green-200)' : 'var(--green-600)'};`}
        >
          {day.hijri.day}
        </span>

        {/* .d-jawa: 0.55rem/400 */}
        {!compact && (
          <span
            class="leading-none"
            style={`font-size:0.55rem; font-weight:400;
              color:${day.isToday ? 'rgba(255,255,255,.65)' : 'var(--ink-light)'};`}
          >
            {day.jawa.pasaran}
          </span>
        )}

        {/* Holiday dot: gold-500, 4×4px */}
        {day.isHoliday && !day.isOtherMonth && (
          <span
            class="absolute bottom-[3px] w-1 h-1 rounded-full"
            style="background:var(--gold-500);"
            aria-label={day.holidayName}
          ></span>
        )}
      </div>
    ))}
  </div>

  <!-- Footer -->
  <div class="flex items-center justify-between px-4 py-2.5 text-[0.72rem]"
       style="border-top:1px solid rgba(29,107,66,.12); color:var(--ink-light);">
    <div class="flex items-center gap-3">
      <span class="flex items-center gap-1">
        <span class="w-1.5 h-1.5 rounded-full inline-block" style="background:var(--gold-500);"></span>
        Libur
      </span>
      <span class="flex items-center gap-1">
        <span class="w-1.5 h-1.5 rounded-full inline-block" style="background:var(--green-700);"></span>
        Hari Ini
      </span>
    </div>
    <a href={`/kalender/${year}`}
       class="font-medium no-underline transition-colors duration-150"
       style="color:var(--green-600) !important;">
      Lihat kalender penuh →
    </a>
  </div>
</div>
