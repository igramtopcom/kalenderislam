---
import BaseLayout from '@/layouts/BaseLayout.astro';
import JsonLD from '@/components/seo/JsonLD.astro';
import { gregorianToHijri, gregorianToJawa } from '@/lib/calendar';
import { getKemenagOfficialDates, getNationalHolidaysSafe, getAllHariBesar } from '@/lib/data';
import CalendarGrid from '@/components/calendar/CalendarGrid.astro';
import TodayWidget from '@/components/islands/TodayWidget.tsx';
import PrayerBar from '@/components/islands/PrayerBar.tsx';

// ── Tanggal hari ini (server-side) ───────────────────────────────────────────
const today       = new Date();
const todayHijri  = gregorianToHijri(today);
const todayJawa   = gregorianToJawa(today);

const HARI_INDO = ['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu'];
const BULAN_INDO = [
  'Januari','Februari','Maret','April','Mei','Juni',
  'Juli','Agustus','September','Oktober','November','Desember'
];

const hariIni   = HARI_INDO[today.getDay()];
const tanggal   = today.getDate();
const bulan     = BULAN_INDO[today.getMonth()];
const tahun     = today.getFullYear();

// ── Data kalender ────────────────────────────────────────────────────────────
const currentYear  = today.getFullYear();
const currentMonth = today.getMonth();

// Fetch currentYear + nextYear for cross-year transition
const [officialDatesCurrent, officialDatesNext] = await Promise.all([
  getKemenagOfficialDates(currentYear),
  getKemenagOfficialDates(currentYear + 1),
]);
const officialDates = [...officialDatesCurrent, ...officialDatesNext];
const holidays      = await getNationalHolidaysSafe(currentYear);

// ── Hari besar mendatang ─────────────────────────────────────────────────────
const hariBesarList = getAllHariBesar();
// Use yesterday as cutoff to handle UTC/WIB timezone mismatch during build
const yesterday = new Date(today.getFullYear(), today.getMonth(), today.getDate() - 1);

const upcomingEvents = officialDates
  .filter(d => {
    if (!d.bestDate) return false;
    const eventDate = new Date(d.bestDate + 'T12:00:00');
    return eventDate >= yesterday;
  })
  .sort((a, b) =>
    new Date(a.bestDate! + 'T12:00:00').getTime() - new Date(b.bestDate! + 'T12:00:00').getTime()
  )
  .slice(0, 4);

// ── Countdown Ramadan ────────────────────────────────────────────────────────
const ramadanData  = officialDates.find(d => d.event === 'ramadan_start');
const ramadanDate  = ramadanData?.bestDate ? new Date(ramadanData.bestDate + 'T12:00:00') : null;
const todayNoonRamadan = new Date(today.getFullYear(), today.getMonth(), today.getDate(), 12);
const daysToRamadan = ramadanDate
  ? Math.round((ramadanDate.getTime() - todayNoonRamadan.getTime()) / 86_400_000)
  : null;

const speakableJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  'name': `Kalender Islam ${tahun} — Tanggal Hijriah Hari Ini`,
  'speakable': {
    '@type': 'SpeakableSpecification',
    'cssSelector': ['#tanggal-hijri-hari-ini'],
  },
  'url': 'https://kalenderislam.id/',
};

const metaTitle = `Kalender Islam ${tahun} — ${todayHijri.day} ${todayHijri.monthName} ${todayHijri.year} H Hari Ini | KalenderIslam.id`;
const metaDesc = `Hari ini ${hariIni}, ${tanggal} ${bulan} ${tahun} = ` +
  `${todayHijri.day} ${todayHijri.monthName} ${todayHijri.year} H = ` +
  `${todayJawa.weton} (Neptu ${todayJawa.neptu}). ` +
  `Kalender Islam lengkap Hijriah, Masehi, dan Jawa untuk Muslim Indonesia.`;
---

<BaseLayout title={metaTitle} description={metaDesc} canonicalPath="/">

  <JsonLD schema={speakableJsonLd} />

  <!-- PRAYER TIMES BAR (real-time with geolocation) -->
  <div style="background: var(--green-900);" class="py-2 px-[clamp(1rem,4vw,3rem)]">
    <div class="max-w-site mx-auto">
      <PrayerBar client:load />
    </div>
  </div>

  <!-- TRUST BAR -->
  <div
    style="background:var(--green-50); border-bottom:1px solid rgba(29,107,66,.12);"
    class="py-2 px-[clamp(1rem,4vw,3rem)]"
  >
    <div
      class="max-w-site mx-auto flex items-center justify-center gap-6 flex-wrap"
      style="color:var(--ink-light); font-size:0.75rem;"
    >
      {[
        { icon: '📅', text: '1.100+ Halaman Kalender' },
        { icon: '📍', text: '100+ Kota Indonesia' },
        { icon: '✅', text: 'Data Kemenag RI' },
        { icon: '🔄', text: 'Diperbarui Otomatis' },
      ].map((item, i) => (
        <>
          <span class="flex items-center gap-1.5 whitespace-nowrap">
            <span>{item.icon}</span>
            <span>{item.text}</span>
          </span>
          {i < 3 && (
            <span style="color:rgba(29,107,66,.25);">·</span>
          )}
        </>
      ))}
    </div>
  </div>

  <!-- HERO SECTION — 2 Column Layout (stretch) -->
  <section class="max-w-site mx-auto px-[clamp(1rem,4vw,3rem)]"
           style="padding-top: clamp(2rem,5vw,4rem); padding-bottom: 2.5rem;">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_440px] gap-5 items-stretch">

      <!-- TODAY CARD (h-full to match Calendar height) -->
      <div
        class="rounded-3xl relative overflow-hidden animate-fade-up h-full flex flex-col"
        style="background: var(--green-800); padding: 1.5rem 2rem 1.25rem;"
      >
        <!-- Pattern overlay -->
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
          <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <pattern id="hex" x="0" y="0" width="56" height="48" patternUnits="userSpaceOnUse">
                <path d="M28 4 L52 18 L52 46 L28 60 L4 46 L4 18 Z"
                      fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
              </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#hex)"/>
          </svg>
        </div>

        <div class="relative z-10 flex flex-col justify-between h-full">
          <!-- Bismillah -->
          <div class="text-center mb-2 text-[1.4rem]"
               style="color: rgba(226,188,69,.7); font-family: 'Amiri', serif;">
            بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ
          </div>

          <!-- Label -->
          <p class="text-[0.68rem] font-semibold uppercase tracking-widest mb-1.5"
             style="color: var(--green-200); opacity: .7;">
            Hari Ini
          </p>

          <!-- SSR Text untuk Googlebot — visually hidden tapi semantically present -->
          <div
            id="tanggal-hijri-hari-ini"
            aria-hidden="false"
            style="position:absolute; width:1px; height:1px; overflow:hidden;
                   clip:rect(0,0,0,0); white-space:nowrap;"
          >
            <h2>Tanggal Hijriah Hari Ini</h2>
            <p>
              Hari ini {hariIni}, {tanggal} {bulan} {tahun} bertepatan dengan
              {todayHijri.day} {todayHijri.monthName} {todayHijri.year} H
              dalam kalender Hijriah.
              Weton Jawa hari ini adalah {todayJawa.weton} dengan neptu {todayJawa.neptu}.
            </p>
          </div>

          <!-- Real-time Today Widget (client:load Island) -->
          <TodayWidget client:load />

          <!-- Divider -->
          <div style="height:1px; background:rgba(255,255,255,.08); margin: 0.4rem 0;"></div>

          <!-- Upcoming event — single card to keep height balanced -->
          <div class="flex flex-col gap-2">
            {upcomingEvents.slice(0, 1).map(event => {
              const hb = hariBesarList.find(h => h.event_id === event.event);
              if (!event.bestDate || !hb) return null;

              const eventDate = new Date(event.bestDate + 'T12:00:00');
              const todayNoon = new Date(today.getFullYear(), today.getMonth(), today.getDate(), 12);
              const daysLeft  = Math.max(0, Math.round((eventDate.getTime() - todayNoon.getTime()) / 86_400_000));
              const label     = daysLeft === 0 ? '🎉 Hari Ini'
                              : daysLeft === 1 ? '⭐ Besok'
                              : `${daysLeft} hari lagi`;

              return (
                <a
                  href={`/hari-besar/${hb.slug}/${eventDate.getFullYear()}`}
                  class="flex items-center gap-3 rounded-lg px-3 py-2.5 no-underline
                         transition-colors duration-150 group"
                  style="background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.09);"
                >
                  {/* Countdown box */}
                  <div
                    class="min-w-[42px] h-[42px] rounded-lg flex flex-col items-center
                           justify-center flex-shrink-0 text-center"
                    style="background:rgba(255,255,255,.08);"
                  >
                    <span class="text-[1rem] font-bold leading-none" style="color:var(--gold-400);">
                      {daysLeft === 0 ? '🎉' : daysLeft === 1 ? '⭐' : daysLeft}
                    </span>
                    {daysLeft > 1 && (
                      <span class="text-[0.55rem] uppercase tracking-wide mt-0.5"
                            style="color:rgba(255,255,255,.4);">hari</span>
                    )}
                  </div>

                  {/* Info */}
                  <div class="flex-1 min-w-0">
                    <p class="text-[0.82rem] font-semibold truncate" style="color:white;">
                      {hb.nama}
                    </p>
                    <p class="text-[0.72rem] mt-0.5" style="color:var(--green-200);">
                      {eventDate.toLocaleDateString('id-ID', { day:'numeric', month:'long' })}
                      {!event.isConfirmed && (
                        <span class="ml-1.5 text-[0.62rem] px-1.5 py-0.5 rounded-full"
                              style="background:rgba(254,243,199,.12); color:rgba(254,243,199,.7);">
                          Perkiraan
                        </span>
                      )}
                    </p>
                  </div>

                  {/* Badge hari libur */}
                  {hb.libur_nasional && (
                    <span class="flex-shrink-0 text-[0.62rem] font-semibold px-2 py-0.5 rounded-full hidden sm:inline"
                          style="background:rgba(201,162,39,.2); color:var(--gold-400);">
                      Libur
                    </span>
                  )}
                </a>
              );
            })}
          </div>
        </div>
      </div>

      <!-- CALENDAR PREVIEW -->
      <div class="animate-fade-up-delay">
        <CalendarGrid
          year={currentYear}
          month={currentMonth}
          holidays={holidays}
          officialDates={officialDates}
          compact={false}
        />
      </div>

    </div>
  </section>

  <!-- TOOLS GRID -->
  <section class="max-w-site mx-auto px-[clamp(1rem,4vw,3rem)] mb-10">
    <h2 class="text-[1.4rem] font-semibold mb-5"
        style="font-family:'Lora',serif; color:var(--ink);">
      Tools Islami
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {[
        { href:'/konversi',          icon:'🔄', title:'Konverter Tanggal',   desc:'Konversi Masehi ↔ Hijri ↔ Jawa secara instan' },
        { href:'/weton',             icon:'⭐', title:'Kalkulator Weton',    desc:'Cari tahu weton dan neptu tanggal lahirmu' },
        { href:'/sholat/jakarta',    icon:'🕌', title:'Jadwal Sholat',       desc:'Waktu sholat 5 waktu untuk 100+ kota Indonesia' },
        { href:'/ramadan/2026',      icon:'🌙', title:'Kalender Ramadan',    desc:'Imsakiyah lengkap Ramadan 2026 per kota' },
        { href:'/hari-besar/idul-fitri/2026', icon:'🎉', title:'Hari Besar Islam', desc:'Tanggal resmi Kemenag + countdown hari besar' },
        { href:'/libur-nasional/2026', icon:'📅', title:'Libur Nasional',   desc:'Daftar hari libur & cuti bersama 2026' },
      ].map(tool => (
        <a
          href={tool.href}
          class="group relative block rounded-2xl p-5 transition-all duration-200 no-underline overflow-hidden"
          style="background:white; border:1px solid rgba(29,107,66,.12);"
        >
          <div class="absolute top-0 left-0 right-0 h-[3px] origin-left transition-transform duration-[250ms] ease-out scale-x-0 group-hover:scale-x-100"
               style="background:var(--green-500);"></div>
          <span class="absolute top-4 right-4 text-[0.9rem] opacity-0 group-hover:opacity-100 transition-opacity duration-200"
                style="color:var(--green-400);">→</span>

          <div class="w-[38px] h-[38px] rounded-[10px] flex items-center justify-center text-xl mb-3"
               style="background:var(--green-50);">
            {tool.icon}
          </div>
          <h3 class="text-[0.92rem] font-semibold mb-1" style="color:var(--ink);">
            {tool.title}
          </h3>
          <p class="text-[0.78rem] leading-relaxed" style="color:var(--ink-light);">
            {tool.desc}
          </p>
        </a>
      ))}
    </div>
  </section>

  <!-- HARI BESAR MENDATANG (standalone section for all screens) -->
  {upcomingEvents.length > 0 && (
    <section class="max-w-site mx-auto px-[clamp(1rem,4vw,3rem)] mb-10">
      <h2 class="text-[1.4rem] font-semibold mb-5"
          style="font-family:'Lora',serif; color:var(--ink);">
        Hari Besar Mendatang
      </h2>
      <div class="flex flex-col gap-3">
        {upcomingEvents.map(event => {
          const hariBesar = hariBesarList.find(h => h.event_id === event.event);
          if (!event.bestDate || !hariBesar) return null;

          const eventDate = new Date(event.bestDate + 'T12:00:00');
          const todayNoon = new Date(today.getFullYear(), today.getMonth(), today.getDate(), 12);
          const daysLeft  = Math.max(0, Math.round((eventDate.getTime() - todayNoon.getTime()) / 86_400_000));
          const tglFormatted = eventDate.toLocaleDateString('id-ID', {
            day:'numeric', month:'long', year:'numeric'
          });

          return (
            <a
              href={`/hari-besar/${hariBesar.slug}/${eventDate.getFullYear()}`}
              class="flex items-center gap-4 rounded-xl p-4 transition-colors duration-150 no-underline group"
              style="background:white; border:1px solid rgba(29,107,66,.12);"
            >
              <div class="min-w-[72px] rounded-lg p-2 text-center flex-shrink-0"
                   style="background:var(--green-50);">
                <p class="text-[1.3rem] font-bold leading-none" style="color:var(--green-700);">
                  {daysLeft}
                </p>
                <p class="text-[0.62rem] uppercase tracking-wider mt-0.5"
                   style="color:var(--ink-light);">hari lagi</p>
              </div>

              <div class="flex-1 min-w-0">
                <h3 class="text-[0.9rem] font-semibold truncate" style="color:var(--ink);">
                  {hariBesar.nama}
                </h3>
                <p class="text-[0.78rem] mt-0.5" style="color:var(--ink-light);">
                  {tglFormatted}
                  {!event.isConfirmed && (
                    <span class="ml-1.5 text-[0.65rem] font-semibold px-1.5 py-0.5 rounded-full"
                          style="background:#FEF3C7; color:#92400E;">Perkiraan</span>
                  )}
                </p>
              </div>

              {hariBesar.libur_nasional && (
                <span class="flex-shrink-0 text-[0.65rem] font-semibold px-2 py-1 rounded-full hidden sm:inline"
                      style="background:var(--gold-100); color:var(--gold-600);">
                  Hari Libur
                </span>
              )}
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- RAMADAN BANNER -->
  {daysToRamadan && daysToRamadan > 0 && (
    <section class="max-w-site mx-auto px-[clamp(1rem,4vw,3rem)] mb-10">
      <div
        class="rounded-2xl relative overflow-hidden"
        style="background: linear-gradient(135deg, var(--green-800) 0%, var(--green-900) 100%);
               padding: 1.8rem 2rem;"
      >
        <div class="absolute right-[-20px] top-[-20px] w-[200px] h-[200px] pointer-events-none opacity-5" aria-hidden="true">
          <svg viewBox="0 0 200 200"><circle cx="100" cy="100" r="90" fill="none" stroke="white" stroke-width="2"/><circle cx="100" cy="100" r="60" fill="none" stroke="white" stroke-width="2"/></svg>
        </div>

        <div class="relative z-10 grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-6 items-center">
          <div>
            <p class="text-[0.7rem] font-semibold uppercase tracking-widest mb-2"
               style="color:var(--green-200); opacity:.7;">Menuju Ramadan</p>
            <h2 class="text-[1.5rem] font-bold text-white mb-2"
                style="font-family:'Lora',serif;">
              Persiapkan Dirimu
            </h2>
            <p class="text-[0.85rem]" style="color:var(--green-200);">
              Ramadan {ramadanDate?.toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric'})}
              {!ramadanData?.isConfirmed && ' (perkiraan)'}
            </p>
          </div>

          <div class="flex items-end gap-4">
            <div class="text-center">
              <p class="text-[1.6rem] font-bold"
                 style="font-family:'Lora',serif; color:var(--gold-400); line-height:1;">
                {daysToRamadan}
              </p>
              <p class="text-[0.62rem] uppercase tracking-wider mt-1"
                 style="color:var(--green-200);">Hari</p>
            </div>
            <a
              href="/ramadan/2026"
              class="px-5 py-2.5 rounded-[10px] text-[0.85rem] font-bold transition-colors duration-150 no-underline"
              style="background:var(--gold-500); color:var(--green-900);"
            >
              Lihat Imsakiyah →
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- TENTANG KALENDERISLAM.ID -->
  <section
    class="max-w-site mx-auto px-[clamp(1rem,4vw,3rem)] py-10"
    style="border-top:1px solid rgba(29,107,66,.1);"
  >
    <div class="max-w-3xl">
      <h2
        class="font-serif text-[1.2rem] font-semibold mb-4"
        style="font-family:'Lora',serif; color:var(--ink);"
      >
        Tentang KalenderIslam.id
      </h2>
      <div
        class="space-y-3 text-[0.9rem] leading-relaxed"
        style="color:var(--ink-light);"
      >
        <p>
          KalenderIslam.id adalah referensi kalender Islam terlengkap untuk Muslim Indonesia.
          Kami menyajikan Kalender Hijriah, Masehi, dan Jawa dalam satu tampilan —
          satu-satunya platform yang menggabungkan ketiga sistem penanggalan yang digunakan
          sehari-hari oleh masyarakat Indonesia.
        </p>
        <p>
          Seluruh data kalender dihitung menggunakan algoritma yang diverifikasi berdasarkan
          data resmi Kementerian Agama Republik Indonesia (Kemenag RI). Tanggal hari besar
          Islam seperti Ramadan, Idul Fitri, dan Idul Adha diperbarui otomatis setelah
          hasil sidang isbat diumumkan.
        </p>
        <p>
          Tersedia untuk 100+ kota di Indonesia dengan jadwal sholat, imsakiyah Ramadan,
          kalkulator weton, dan konverter tanggal tiga sistem sekaligus.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>
