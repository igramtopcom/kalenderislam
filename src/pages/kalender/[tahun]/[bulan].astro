---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CalendarGrid from '@/components/calendar/CalendarGrid.astro';
import {
  BULAN_SLUG, SLUG_BULAN,
  generateMonthCalendar,
} from '@/lib/calendar';
import { getNationalHolidaysSafe, getKemenagOfficialDates } from '@/lib/data';

export async function getStaticPaths() {
  const tahunRange = Array.from({ length: 9 }, (_, i) => 2024 + i);
  const bulanSlugs = Object.keys(BULAN_SLUG);

  return tahunRange.flatMap(tahun =>
    bulanSlugs.map(bulan => ({
      params: { tahun: String(tahun), bulan },
      props:  { tahun, bulanSlug: bulan },
    }))
  );
}

const { tahun, bulanSlug } = Astro.props as { tahun: number; bulanSlug: string };
const month = BULAN_SLUG[bulanSlug];

const [holidays, officialDates] = await Promise.all([
  getNationalHolidaysSafe(tahun),
  getKemenagOfficialDates(tahun),
]);

const holidayMap = new Map(holidays.map(h => [h.tanggal, h]));
const cal = generateMonthCalendar(tahun, month, holidayMap);

// Hari libur bulan ini
const monthStr = String(month + 1).padStart(2, '0');
const holidaysThisMonth = holidays.filter(h =>
  h.tanggal.startsWith(`${tahun}-${monthStr}`)
);

// SEO
const bulanCapital = bulanSlug.charAt(0).toUpperCase() + bulanSlug.slice(1);
const title = `Kalender Islam ${bulanCapital} ${tahun} — Hijriah & Jawa | KalenderIslam.id`;
const desc  = `Kalender Islam ${bulanCapital} ${tahun} lengkap dengan tanggal Hijriah, Jawa, dan hari libur nasional. Akurat sesuai Kemenag RI.`;

// Prev/Next URLs
const prevUrl = `/kalender/${cal.prevMonth.year}/${SLUG_BULAN[cal.prevMonth.month]}`;
const nextUrl = `/kalender/${cal.nextMonth.year}/${SLUG_BULAN[cal.nextMonth.month]}`;
---

<BaseLayout
  title={title}
  description={desc}
  canonicalPath={`/kalender/${tahun}/${bulanSlug}`}
>
  <div class="max-w-site mx-auto px-[clamp(1rem,4vw,3rem)] py-8">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 mb-4 flex-wrap">
      <a href="/" class="text-[0.78rem] no-underline" style="color:var(--ink-light) !important;">Beranda</a>
      <span style="color:var(--ink-light);">›</span>
      <a href={`/kalender/${tahun}`} class="text-[0.78rem] no-underline" style="color:var(--ink-light) !important;">Kalender {tahun}</a>
      <span style="color:var(--ink-light);">›</span>
      <span class="text-[0.78rem] font-medium" style="color:var(--ink);">{bulanCapital}</span>
    </div>

    <!-- Page Header + Nav -->
    <div class="flex items-start justify-between gap-4 mb-6 flex-wrap">
      <div>
        <h1 class="text-[1.8rem] font-bold"
            style="font-family:'Lora',serif; color:var(--ink);">
          {bulanCapital} {tahun}
        </h1>
        <p class="text-[0.9rem] mt-0.5" style="color:var(--ink-light);">
          {cal.hijriLabel}
        </p>
      </div>
      <div class="flex items-center gap-2">
        <a href={prevUrl}
           class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-[0.8rem] font-medium
                  no-underline transition-colors duration-150"
           style="border:1px solid rgba(29,107,66,.12); background:white; color:var(--ink-muted) !important;">
          ‹ Sebelumnya
        </a>
        <a href={`/kalender/${tahun}`}
           class="px-3 py-2 rounded-lg text-[0.8rem] font-medium no-underline transition-colors duration-150"
           style="background:var(--green-50); color:var(--green-700) !important; border:1px solid rgba(29,107,66,.12);">
          {tahun}
        </a>
        <a href={nextUrl}
           class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-[0.8rem] font-medium
                  no-underline transition-colors duration-150"
           style="border:1px solid rgba(29,107,66,.12); background:white; color:var(--ink-muted) !important;">
          Berikutnya ›
        </a>
      </div>
    </div>

    <!-- Layout: Calendar (kiri) + Sidebar (kanan) -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-6">

      <!-- Calendar Grid -->
      <CalendarGrid
        year={tahun}
        month={month}
        holidays={holidays}
        officialDates={officialDates}
        showNav={false}
      />

      <!-- Sidebar -->
      <aside class="flex flex-col gap-4">

        <!-- Hari Libur Bulan Ini -->
        <div class="rounded-2xl overflow-hidden"
             style="background:white; border:1px solid rgba(29,107,66,.12);">
          <div class="px-4 py-3"
               style="background:var(--green-50); border-bottom:1px solid rgba(29,107,66,.12);">
            <h2 class="text-[0.85rem] font-semibold" style="color:var(--ink);">
              Hari Libur {bulanCapital}
            </h2>
          </div>
          <div class="p-3">
            {holidaysThisMonth.length === 0 ? (
              <p class="text-[0.8rem] py-2 text-center" style="color:var(--ink-light);">
                Tidak ada hari libur bulan ini
              </p>
            ) : (
              <ul class="space-y-2 list-none p-0 m-0">
                {holidaysThisMonth.map(h => {
                  const d = new Date(h.tanggal + 'T12:00:00');
                  return (
                    <li class="flex items-start gap-3">
                      <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center
                                  text-[0.75rem] font-bold mt-0.5"
                           style="background:var(--green-50); color:var(--green-700);">
                        {d.getDate()}
                      </div>
                      <div>
                        <p class="text-[0.82rem] font-medium leading-tight" style="color:var(--ink);">
                          {h.nama}
                        </p>
                        <span class="text-[0.65rem] font-semibold px-1.5 py-0.5 rounded-full"
                              style={h.tipe === 'libur_nasional'
                                ? 'background:var(--gold-100); color:var(--gold-600);'
                                : 'background:var(--green-100); color:var(--green-700);'}>
                          {h.tipe === 'libur_nasional' ? 'Libur Nasional' : 'Cuti Bersama'}
                        </span>
                      </div>
                    </li>
                  );
                })}
              </ul>
            )}
          </div>
        </div>

        <!-- Quick Jump ke bulan lain -->
        <div class="rounded-2xl overflow-hidden"
             style="background:white; border:1px solid rgba(29,107,66,.12);">
          <div class="px-4 py-3"
               style="background:var(--green-50); border-bottom:1px solid rgba(29,107,66,.12);">
            <h2 class="text-[0.85rem] font-semibold" style="color:var(--ink);">
              Bulan Lain {tahun}
            </h2>
          </div>
          <div class="p-3 grid grid-cols-3 gap-1.5">
            {Object.entries(BULAN_SLUG).map(([slug, m]) => {
              const nama = slug.charAt(0).toUpperCase() + slug.slice(1, 3);
              return (
                <a
                  href={`/kalender/${tahun}/${slug}`}
                  class="py-1.5 rounded-md text-center text-[0.75rem] font-medium
                         no-underline transition-colors duration-150"
                  style={m === month
                    ? 'background:var(--green-700); color:white !important;'
                    : 'background:var(--green-50); color:var(--ink-muted) !important;'}
                >
                  {nama}
                </a>
              );
            })}
          </div>
        </div>

      </aside>
    </div>

  </div>
</BaseLayout>
